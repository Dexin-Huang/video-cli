{
  "name": "video-cli",
  "version": "0.2.6",
  "description": "Local-first video REPL for AI agents — search, ask, navigate, extract",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "video-cli": "video-cli.js"
  },
  "engines": {
