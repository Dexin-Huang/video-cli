{
  "name": "video-cli",
  "version": "0.2.4",
  "description": "Local-first video REPL for AI agents — search, ask, navigate, extract",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "video-cli": "video-cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "video-cli.js",
    "src/",
    "skills/",
    "SKILL.md",
    "README.md",
    ".env.example",
    "video-cli.config.example.json"
  ],
  "keywords": [
    "video",
    "search",
    "cli",
    "agent",
    "transcription",
    "ocr",
    "llm",
    "gemini",
    "elevenlabs",
    "repl"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Dexin-Huang/video-cli"
  },
  "scripts": {
    "test": "node --test --experimental-test-isolation=none",
    "skills:sync": "node scripts/sync-skill-docs.js",
    "skills:check": "node scripts/sync-skill-docs.js --check",
    "eval": "node evals/run.js",
    "eval:json": "node evals/run.js --json",
    "goldens:check": "node goldens/validate.js",
    "goldens:check:json": "node goldens/validate.js --json",
    "goldens:eval": "node goldens/run.js",
    "goldens:eval:json": "node goldens/run.js --json"
  }
}
