  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dexin-Huang/video-cli.git"
  },
  "scripts": {
    "test": "node --test --experimental-test-isolation=none",
    "eval": "node evals/run.js",
    "eval:json": "node evals/run.js --json"
  }
}
