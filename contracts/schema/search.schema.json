{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video-cli.local/schemas/cli/search.schema.json",
  "title": "video-cli search output",
  "type": "object",
  "required": ["id", "query", "matchCount", "matches"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "query": { "type": "string", "minLength": 1 },
    "matchCount": { "type": "number", "minimum": 0 },
    "matches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["score", "source", "index", "atSec", "startSec", "endSec", "speaker", "framePath", "text"],
        "properties": {
          "score": { "type": "number" },
          "source": { "type": "string", "minLength": 1 },
          "index": { "type": ["number", "null"] },
          "atSec": { "type": ["number", "null"] },
          "startSec": { "type": ["number", "null"], "minimum": 0 },
          "endSec": { "type": ["number", "null"], "minimum": 0 },
          "speaker": { "type": ["string", "null"] },
          "framePath": { "type": ["string", "null"] },
          "text": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
