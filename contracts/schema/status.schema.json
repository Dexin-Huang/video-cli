{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video-cli.local/schemas/cli/status.schema.json",
  "title": "video-cli status output",
  "type": "object",
  "required": ["id", "sourceName", "durationSec", "artifacts", "readyForAsk", "readyForSearch"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "sourceName": { "type": "string", "minLength": 1 },
    "durationSec": { "type": "number", "minimum": 0 },
    "artifacts": {
      "type": "object",
      "required": ["transcript", "ocr", "embeddings", "descriptions"],
      "properties": {
        "transcript": { "type": "boolean" },
        "ocr": { "type": "boolean" },
        "embeddings": { "type": "boolean" },
        "descriptions": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "readyForAsk": { "type": "boolean" },
    "readyForSearch": { "type": "boolean" }
  },
  "additionalProperties": false
}
