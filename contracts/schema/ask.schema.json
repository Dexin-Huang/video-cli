{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video-cli.local/schemas/cli/ask.schema.json",
  "title": "video-cli ask output",
  "type": "object",
  "required": ["id", "query", "answer", "citations", "suggestedFollowUps", "hints"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "query": { "type": "string", "minLength": 1 },
    "answer": { "type": "string", "minLength": 1 },
    "confidence": { "type": ["string", "null"], "enum": ["high", "partial", "low", null] },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["atSec", "source", "text", "framePath"],
        "properties": {
          "atSec": { "type": "number", "minimum": 0 },
          "source": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 },
          "framePath": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "suggestedFollowUps": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "hints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "message"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 },
          "framePath": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
